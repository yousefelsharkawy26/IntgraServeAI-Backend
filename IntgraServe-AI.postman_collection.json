	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Save access token to environment variable",
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_token\", jsonData.token);",
									"    console.log(\"Access token saved:\", jsonData.token);",
									"    ",
									"    // Extract and save refresh token from cookies",
									"    var cookies = pm.cookies.all();",
									"    cookies.forEach(cookie => {",
									"        if (cookie.name === 'refresh_token') {",
									"            pm.environment.set(\"refresh_token\", cookie.value);",
									"            console.log(\"Refresh token saved from cookie\");",
									"        }",
									"    });",
									"    ",
									"    pm.test(\"Login successful\", function () {",
									"        pm.response.to.have.status(200);",
									"        pm.expect(jsonData.token).to.be.a('string');",
									"    });",
									"} else {",
									"    pm.test(\"Login failed\", function () {",
									"        pm.response.to.have.status(401);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@integraserve-ai.com\",\n  \"password\": \"Admin@123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						},
						"description": "Login with email and password. Returns access token in body and sets refresh token in httpOnly cookie."
					},
					"response": []
				},
				{
					"name": "Login - Invalid Credentials",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Should return 401 for invalid credentials\", function () {",
									"    pm.response.to.have.status(401);",
									"});",
									"",
									"pm.test(\"Should return error message\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.detail.message).to.include('Invalid email or password');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@integraserve-ai.com\",\n  \"password\": \"WrongPassword123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						},
						"description": "Test login with invalid credentials"
					},
					"response": []
				},
				{
					"name": "Forgot Password",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Password reset email sent\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.include('Password reset Link have been sent');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@integraserve-ai.com\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/forgot-password",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"forgot-password"
							]
						},
						"description": "Request password reset link. Always returns success to prevent email enumeration."
					},
					"response": []
				},
				{
					"name": "Reset Password",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Password reset successful\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.include('Password has been reset successfully');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"new_password\": \"NewPassword@123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/v1/auth/reset-password?token={{reset_token}}",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"reset-password"
							],
							"query": [
								{
									"key": "token",
									"value": "{{reset_token}}",
									"description": "Reset token from email (you need to get this from email or generate manually)"
								}
							]
						},
						"description": "Reset password using token from email. Note: You need to get the token from the email sent in 'Forgot Password' step."
					},
					"response": []
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"access_token\", jsonData.token);",
									"    console.log(\"New access token saved:\", jsonData.token);",
									"    ",
									"    pm.test(\"Token refreshed successfully\", function () {",
									"        pm.response.to.have.status(200);",
									"        pm.expect(jsonData.token).to.be.a('string');",
									"    });",
									"} else {",
									"    pm.test(\"Refresh failed\", function () {",
									"        pm.response.to.have.status(401);",
									"    });",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"// This endpoint uses refresh_token from cookies automatically",
									"console.log(\"Refresh token from cookies will be used automatically\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/refresh",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"refresh"
							]
						},
						"description": "Get a new access token using the refresh token stored in httpOnly cookie. The refresh token is sent automatically by the browser/Postman."
					},
					"response": []
				},
				{
					"name": "Logout",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Logout successful\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.message).to.include('Logged out successfully');",
									"});",
									"",
									"// Clear tokens from environment",
									"pm.environment.unset(\"access_token\");",
									"pm.environment.unset(\"refresh_token\");",
									"console.log(\"Tokens cleared from environment\");"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/v1/auth/logout",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"logout"
							]
						},
						"description": "Logout user and clear refresh token cookie."
					},
					"response": []
				},
